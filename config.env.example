# unit3dprep Docker config — copy to `config.env` and fill in.
# Passed verbatim to the container via docker-compose `env_file:` (no shell
# expansion), so the '$' characters in the bcrypt hash are safe as-is.

# bcrypt hash of your web UI password. Generate it with:
#   docker compose run -it --rm --entrypoint python unit3dprep /app/generate_hash.py
# Paste the single $2b$... value below (do NOT wrap in quotes).
U3DP_PASSWORD_HASH=

# Random secret for signing session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
U3DP_SECRET=

# TMDB API key (v3). https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Keep 0 when serving plain HTTP on loopback (default). Set to 1 ONLY when a
# TLS reverse proxy terminates HTTPS in front of the app — otherwise the
# session cookie becomes https-only and login silently fails (endless 401).
U3DP_HTTPS_ONLY=0

# User/group the stack runs as inside the container. Files written under the
# ./data volume (config, db, torrents, hardlinks) are owned by these ids, so
# set them to YOUR host user to manage media/seedings without sudo:
#   run `id` on the host and copy the uid/gid here.
# Defaults to 1000:1000 (the first Linux/WSL user). Set PUID=0 to run as root.
PUID=1000
PGID=1000

# --- Optional: seed settings on first boot (headless setup) -----------------
# These are read ONLY when the shared .env doesn't exist yet (first boot) and
# written into it so Unit3DWebUp picks them up at startup. Afterwards edit
# everything from the web UI → Settings (the .env becomes authoritative; these
# env vars are ignored on later boots). Leave blank to configure via the UI.
#
# ITT tracker credentials:
#ITT_APIKEY=
#ITT_PID=
# Extra metadata API (TMDB above already seeds webup):
#TVDB_APIKEY=
# qBittorrent client (use host.docker.internal for a qBit on the host):
#QBIT_HOST=
#QBIT_PORT=
#QBIT_USER=
#QBIT_PASS=
